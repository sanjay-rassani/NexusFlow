# ──────────────────────────────────────────────
# NexusFlow Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ────────────────────────────
# Django Core
# ────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here-change-me
JWT_SECRET_KEY=another-long-random-key-for-jwt-signing
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ────────────────────────────
# Database (PostgreSQL)
# ────────────────────────────
DATABASE_URL=postgres://nexusflow:nexusflow@localhost:5432/nexusflow
POSTGRES_DB=nexusflow
POSTGRES_USER=nexusflow
POSTGRES_PASSWORD=nexusflow

# ────────────────────────────
# Redis
# DB 0 = Django cache
# DB 1 = Channel layers (WebSocket)
# DB 2 = Celery broker
# ────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/2

# ────────────────────────────
# CORS (Frontend URL)
# ────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ────────────────────────────
# Email
# ────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NexusFlow <noreply@nexusflow.com>

# ────────────────────────────
# Sentry (Production only — optional)
# ────────────────────────────
SENTRY_DSN=
